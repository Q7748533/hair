  T:sitemap=auto_update_on_new_page
  T:breadcrumb=real_links_only|each_level_has_page
  T:url_naming=keyword-rich|format=[brand]-[product]-[type].html
  T:cookie_consent=every_page|localStorage_based
  T:og_tags=required:[og:title,og:description,og:image,og:url,og:type,og:site_name]
  T:gsc_submit=within_24h_of_new_page|manual_index:homepage+category_hubs
  T:llms_txt=root_dir|keep_updated_on_new_page|allow:Googlebot+GPTBot+ClaudeBot+PerplexityBot
