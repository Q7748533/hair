::GENE{diagnostics|conf:confirmed|scope:global}
  T:diagnostic_order=[ask_symptom,verify_code,verify_deploy,suspect_cache]
  T:cache_config=immutable_1year|/assets/*
  T:code_checks=[brace_balance,class_diff,BOM,unclosed_comments]
  T:deploy_checks=[curl_200,Content-Type,latest_sha]
